{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "bash": "./scripts/copilot_hooks.py session-start"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "bash": "./scripts/copilot_hooks.py session-end"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "bash": "./scripts/copilot_hooks.py post-tool-use"
      }
    ]
  }
}
